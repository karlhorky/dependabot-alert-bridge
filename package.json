{
  "name": "dependabot-alert-bridge",
  "version": "1.0.0",
  "description": "Enable GitHub Actions workflow triggers for Dependabot alerts by bridging dependabot_alert webhooks to repository_dispatch events",
  "keywords": [
    "github-app",
    "dependabot",
    "repository-dispatch",
    "github-actions",
    "webhook"
  ],
  "license": "MIT",
  "author": "Karl Horky",
  "type": "module",
  "scripts": {
    "dev": "node --watch index.ts",
    "lint": "eslint . --max-warnings 0",
    "start": "node index.ts"
  },
  "dependencies": {
    "@octokit/auth-app": "8.2.0",
    "@octokit/request": "10.0.11",
    "@octokit/webhooks": "14.2.0",
    "@octokit/webhooks-types": "7.6.1",
    "arktype": "2.2.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "eslint": "9.39.2",
    "eslint-config-upleveled": "9.4.7",
    "prettier": "3.9.5",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=24"
  }
}
